DEBUG=False
SECRET_KEY=replace-with-secret-manager-or-ssm-value
DATABASE_URL=postgres://datamailer_app:replace@database-endpoint:5432/datamailer
ALLOWED_HOSTS=staging.datamailer.example.com
CSRF_TRUSTED_ORIGINS=https://staging.datamailer.example.com
PUBLIC_BASE_URL=https://staging.datamailer.example.com
DEFAULT_FROM_EMAIL=no-reply@staging.datamailer.example.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
AWS_REGION=us-east-1
AWS_SES_CONFIGURATION_SET=datamailer-staging
DATAMAILER_SES_MAX_SEND_RATE=10
SQS_TRANSACTIONAL_EMAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/staging-transactional-email
SQS_CAMPAIGN_EMAIL_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/staging-campaign-email
SQS_SES_WEBHOOKS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/staging-ses-webhooks
SQS_EMAIL_EVENTS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/staging-email-events
TRANSACTIONAL_EMAIL_QUEUE_NAME=staging-transactional-email
CAMPAIGN_EMAIL_QUEUE_NAME=staging-campaign-email
SES_WEBHOOKS_QUEUE_NAME=staging-ses-webhooks
EMAIL_EVENTS_QUEUE_NAME=staging-email-events
SES_WEBHOOKS_SIGNATURE_MODE=strict
SES_WEBHOOKS_ALLOW_SUBSCRIPTION_CONFIRMATION=False
